<div class="container">
<div>
<h1>Add a new restaurant</h1>
</div>
<br>
<div>
  <%= simple_form_for(@restaurant) do |f| %>
    <%= f.input :name %>
    <%= f.input :address %>
    <%= f.input :phone_number %>
    <%= f.input :category, collection:["chinese", "italian", "japanese", "french belgian"], :class => 'genForm_dropBox' %>
    <%= f.submit class: "btn btn-primary"%>
  <% end %>
</div>
<br>
<%= link_to 'Back', restaurants_path %>
</div>
